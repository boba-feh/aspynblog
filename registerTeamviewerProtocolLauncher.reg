Windows Registry Editor Version 5.00

[HKEY_CLASSES_ROOT\open-teamviewer]
@="URL:Open TeamViewer Protocol"
"URL Protocol"=""

[HKEY_CLASSES_ROOT\open-teamviewer\shell]

[HKEY_CLASSES_ROOT\open-teamviewer\shell\open]

[HKEY_CLASSES_ROOT\open-teamviewer\shell\open\command]
@="powershell.exe -ExecutionPolicy Bypass -File \"C:\\users\\public\\scripts\\open-teamviewer.ps1\" \"%1\""
